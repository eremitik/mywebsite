website/src/reportWebVitals.js",[],"/home/eremitik/play/tryjs/mywebsite/src/App.js",[],"/home/eremitik/play/tryjs/mywebsite/src/About.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Home.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Contact.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Projects.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Ttt/Ttt.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Pokedex/Pokegame.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Rolldice/RollDice.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Carddealer/Deck.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Coinflip/Coinflip.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Lightsout/Board.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Lotto/Lottery.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ColorBox/BoxContainer.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ToDo/TodoList.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Pokedex/Pokedex.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Rolldice/Die.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Carddealer/Card.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Coinflip/helpers.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Coinflip/Coin.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Lotto/Ball.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ToDo/NewTodoForm.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ToDo/Todo.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Lightsout/Cell.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ColorBox/Box.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Pokedex/Pokecard.js",[],"/home/eremitik/play/tryjs/mywebsite/src/ColorBox/helper.js",[],"/home/eremitik/play/tryjs/mywebsite/src/Usexplorer/Usexplorer.js",["122","123","124"],"import React, { useEffect } from 'react'\nimport { HashRouter as Router, Link, Route } from 'react-router-dom';\nimport './Usexplorer.css'\nimport { ApolloClient } from 'apollo-client'\nimport { InMemoryCache } from 'apollo-cache-inmemory'\nimport { HttpLink } from 'apollo-link-http'\nimport { useQuery } from '@apollo/react-hooks'\nimport gql from 'graphql-tag'\nimport uniswapLogo from '../images/uniswap-logo.png'\nimport daiLogo from '../images/dai-logo.png'\nimport zeroxLogo from '../images/zerox.png'\n\nexport const client = new ApolloClient({\n  link: new HttpLink({\n    uri: 'https://api.thegraph.com/subgraphs/name/uniswap/uniswap-v2'\n  }),\n  fetchOptions: {\n    mode: 'no-cors'\n  },\n  cache: new InMemoryCache()\n})\n\nconst DAI_QUERY = gql`\n  query tokens($tokenAddress: Bytes!){\n    tokens(where: {id: $tokenAddress}){\n      derivedETH\n      tradeVolumeUSD\n    }\n  }\n`\n\nconst ETH_PRICE_QUERY = gql`\n  query bundles {\n    bundles(where: {id: \"1\"}){\n      ethPrice\n    }\n  }\n`\n\nconst UNI_QUERY = gql`\n  query tokens($tokenAddress: Bytes!){\n    tokens(where: {id: $tokenAddress}){\n      derivedETH\n      tradeVolumeUSD \n    }\n  }\n`\n\nconst ZRX_QUERY = gql`\n  query token($tokenAddress: Bytes!){\n    tokens(where: {id: $tokenAddress}){\n      derivedETH\n      tradeVolumeUSD\n    }\n  }\n`\n\nfunction Usexplorer() {\n  const {loading: ethLoading, data: ethPriceData} = useQuery(ETH_PRICE_QUERY)\n  const {loading: daiLoading, data: daiData} = useQuery(DAI_QUERY, {\n    variables: {\n      tokenAddress: '0x6b175474e89094c44da98b954eedeac495271d0f'\n    }\n  })\n  const {loading: uniLoading, data: uniData} = useQuery(UNI_QUERY, {\n    variables: {\n      tokenAddress: '0x1f9840a85d5af5bf1d1762f925bdaddc4201f984'\n    }\n  })\n  const {loading: zrxLoading, data: zrxData} = useQuery(ZRX_QUERY, {\n    variables: {\n      tokenAddress: '0xe41d2489571d322189246dafa5ebde1f4699f498'\n    }\n  })\n\n  const daiPriceInEth = daiData && daiData.tokens[0].derivedETH\n  const daiTradeVolumeUSD = daiData && daiData.tokens[0].tradeVolumeUSD\n  const uniPriceInEth = uniData && uniData.tokens[0].derivedETH\n  const uniTradeVolumeUSD = uniData && uniData.tokens[0].tradeVolumeUSD\n  const zrxPriceInEth = zrxData && zrxData.tokens[0].derivedETH\n  const zrxTradeVolumeUSD = zrxData && zrxData.tokens[0].tradeVolumeUSD\n  const ethPriceInUSD = ethPriceData && ethPriceData.bundles[0].ethPrice\n\n  function formatNum(n) {\n    return n.toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\")\n  }\n\n  return (\n    <div className=\"Usexplorer\">\n      <div style={{textAlign:\"center\"}}>\n        <h1 style={{fontSize:\"2.5rem\", fontWeight:\"bold\"}}>🦄Uniswap Explorer</h1>\n        <p style={{fontSize:\"0.8rem\"}}>This simple page was made with GraphQL, using &nbsp; \n          <a href=\"https://thegraph.com/explorer/subgraph/uniswap/uniswap-v2?query=Example%20query\">Uniswap V2 subgraph.</a></p>\n      <div >\n        <br/>\n\n        <div style={{display:\"inline-block\"}}>\n\n          <div style={{textAlign:\"left\", fontSize:\"1rem\"}}>\n                <p>\n                <img src={daiLogo} width=\"30\" height=\"30\" className=\"mb-2\" alt=\"\" />\n                  DAI (Dai Stable Token) \n                  <br/>\n                  Price: {' '}\n                  {ethLoading || daiLoading\n                    ? 'Loading token data...'\n                    : '$' + \n                    (parseFloat(daiPriceInEth) * parseFloat(ethPriceInUSD)).toFixed(2)}\n                  <br/>\n                  Trade volume:{' '}\n                  {daiLoading\n                    ? 'Loading token data...'\n                    : '$' + formatNum(parseFloat(daiTradeVolumeUSD).toFixed(0))}\n                </p>\n              </div>\n              <br/>\n\n              <div style={{textAlign:\"left\", fontSize:\"1rem\"}}>\n                <p>\n                <img src={uniswapLogo} width=\"30\" height=\"30\" className=\"mb-2\" alt=\"\" />\n                  UNI (Uniswap)\n                  <br/>\n                  Price: {' '}\n                  {ethLoading || uniLoading\n                    ? 'Loading token data...'\n                    : '$' + \n                    (parseFloat(uniPriceInEth) * parseFloat(ethPriceInUSD)).toFixed(2)}\n                  <br/>\n                  Trade volume:{' '}\n                  {uniLoading\n                    ? 'Loading token data...'\n                    : '$' + formatNum(parseFloat(uniTradeVolumeUSD).toFixed(0))}\n                </p>\n              </div>\n              <br/>\n\n              <div style={{textAlign:\"left\", fontSize:\"1rem\"}}>\n                <p>\n                <img src={zeroxLogo} width=\"30\" height=\"30\" className=\"mb-2\" alt=\"\" />\n                  ZRX (0x Protocol)\n                  <br/>\n                  Price: {' '}\n                  {ethLoading || zrxLoading\n                    ? 'Loading token data...'\n                    : '$' + \n                    (parseFloat(zrxPriceInEth) * parseFloat(ethPriceInUSD)).toFixed(2)}\n                  <br/>\n                  Trade volume:{' '}\n                  {zrxLoading\n                    ? 'Loading token data...'\n                    : '$' + formatNum(parseFloat(zrxTradeVolumeUSD).toFixed(0))}\n                </p>\n\n              </div>\n            </div>\n        </div>\n      </div>\n        <p style={{letterSpacing:\"-4px\", fontSize:\"8rem\", color:\"white\", fontWeight:\"bold\", textAlign:\"center\"}}><Link to='/projects'>back</Link>\n        </p>\n    </div>\n    \n  );\n}\n\nexport default Usexplorer;\n",{"ruleId":"125","replacedBy":"126"},{"ruleId":"127","replacedBy":"128"},{"ruleId":"129","severity":1,"message":"130","line":1,"column":17,"nodeType":"131","messageId":"132","endLine":1,"endColumn":26},{"ruleId":"129","severity":1,"message":"133","line":2,"column":24,"nodeType":"131","messageId":"132","endLine":2,"endColumn":30},{"ruleId":"129","severity":1,"message":"134","line":2,"column":38,"nodeType":"131","messageId":"132","endLine":2,"endColumn":43},"no-native-reassign",["135"],"no-negated-in-lhs",["136"],"no-unused-vars","'useEffect' is defined but never used.","Identifier","unusedVar","'Router' is defined but never used.","'Route' is defined but never used.","no-global-assign","no-unsafe-negation"]